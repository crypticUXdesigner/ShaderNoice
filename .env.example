# All vars here are client-exposed (Vite inlines VITE_* into the bundle). Do not add server secrets to .env.example.
#
# Optional: show the full-viewport intro splash in dev (normally it only runs in production builds).
# You can also open `?splash=1` on the dev server instead.
# VITE_SHOW_SPLASH=true
#
# Audiograph API (waveform preview for playlist tracks in the mini timeline).
# Default: POST https://rpc.audiotool.com/audiotool.audiograph.v1.AudiographService/GetAudiographs

# Browser CORS blocks direct POSTs to rpc.audiotool.com from dev/prod origins unless their server allows it.
# **Local dev:** omit these — vite.config proxies `/__audiotool_rpc__` → rpc.audiotool.com (same-origin fetch).
# **Production (static host):** you still need server-side relay or rpc CORS whitelist; overriding to https:// rpc does not bypass CORS in the user's browser.

# Optional: Override base URL (no trailing slash). Omit in local dev for automatic `/__audiotool_rpc__` proxy.
# VITE_AUDIOGRAPH_API_URL=https://rpc.audiotool.com

# Optional: CONNECT base for Track listing (manual requests; Nexus has no TrackService stub).
# Omit in local dev — same vite proxy applies (see vite.config.ts `/__audiotool_rpc__`).
# VITE_AUDIOTOOL_RPC_URL=https://rpc.audiotool.com

# Optional: Bearer token if the RPC requires auth. Set when the API demands Authorization.
# VITE_AUDIOTOOL_API_TOKEN=your_token_here
# Note: any VITE_* value is inlined into the client bundle — public configuration only, never a confidential secret.

# Audiotool OAuth (browser, @audiotool/nexus): built-in client id is bundled; sign-in gate is on unless disabled below.
# When the gate is on, the splash still offers **Continue without signing in** — the editor works without Audiotool; OAuth adds account-linked features where implemented.
# Register the app + redirect URIs at https://developer.audiotool.com/applications — each URI must match exactly.
# Audiotool rejects `localhost` in redirect URIs; use 127.0.0.1 (or [::1]). Typical local dev:
#   http://127.0.0.1:3000/ShaderNoice/
# Production (example): https://crypticUXdesigner.github.io/ShaderNoice/
# Optional: force redirect_uri (must not use localhost — dashboard will reject it).
# VITE_AUDIOTOOL_REDIRECT_URI=http://127.0.0.1:3000/ShaderNoice/
# Optional: use another OAuth app (forks).
# VITE_AUDIOTOOL_CLIENT_ID=
# Optional: skip Audiotool gate entirely (local dev without OAuth).
# VITE_AUDIOTOOL_OAUTH_DISABLED=true
# Optional; default is user:read project:read (ShaderNoice track listing needs project:read). Narrow for forks via this var.
# VITE_AUDIOTOOL_OAUTH_SCOPE=user:read
